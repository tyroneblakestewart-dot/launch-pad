# Optional: enables deeper AI vision analysis for artwork-matched website generation.
# Keep this server-side. Never prefix it with NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5-mini

# Required only to run `npm run deploy:factory:robinhood` (see README.md
# "Factory deployment"). Never commit real values. HOODLUMS_FACTORY_DEPLOYER_PRIVATE_KEY
# must be a funded testnet-only key and is never read by the app itself.
ROBINHOOD_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com
HOODLUMS_FACTORY_DEPLOYER_PRIVATE_KEY=
HOODLUMS_FACTORY_OWNER_ADDRESS=
HOODLUMS_FACTORY_TREASURY_ADDRESS=

# Optional: public JSON map of chainId -> deployed HoodlumsTokenFactory
# address, populated once a deployment above is verified. Safe to expose to
# the browser; contains no secrets.
NEXT_PUBLIC_HOODLUMS_FACTORY_ADDRESSES=
